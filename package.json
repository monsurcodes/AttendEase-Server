{
  "name": "attendease-server",
  "version": "0.3.2",
  "description": "High-performance, multi-tenant academic attendance management API built with NestJS, Prisma ORM, and PostgreSQL. Features real-time consensus polling via WebSockets and Redis Pub/Sub, automated geofenced validation, and predictive analytics to optimize student attendance compliance thresholds.",
  "author": "monsurcodes",
  "private": true,
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "pnpm run clean:info && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "format": "prettier . --write",
    "lint": "eslint --fix",
    "clean:info": "rimraf tsconfig.build.tsbuildinfo",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier . --write"
    ]
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.19",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/websockets": "^11.1.27",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@thallesp/nestjs-better-auth": "^2.6.1",
    "better-auth": "^1.6.20",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "escape-html": "^1.0.3",
    "ioredis": "^5.11.1",
    "nestjs-zod": "^5.4.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.27",
    "@types/escape-html": "^1.0.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "standard-version": "^9.5.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
